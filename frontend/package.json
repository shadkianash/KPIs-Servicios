    "@mantine/hooks": "^7.15.0",
    "@tanstack/react-query": "^5.66.0",
    "ag-grid-community": "^36.0.2",
    "ag-grid-react": "^36.0.2",
    "axios": "^1.18.1",
    "echarts": "^6.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.82.0",
    "react-router-dom": "^7.18.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
